# 자금 조류 데일리 파이프라인 비밀키 (템플릿)
# ---------------------------------------------------------
# 이 파일을 scripts/run_daily.env 로 복사하고 값을 채운다.
# run_daily.env 는 .gitignore 되어 저장소에 올라가지 않는다.
#
#   cp scripts/run_daily.env.example scripts/run_daily.env
#   # 그 뒤 아래 두 값을 채운다
#
# 텔레그램 봇 토큰 — @BotFather 에서 봇 생성 시 발급
TELEGRAM_BOT_TOKEN=
# 알림 받을 chat_id — 봇에게 아무 메시지나 보낸 뒤
#   https://api.telegram.org/bot<TOKEN>/getUpdates 의 result[].message.chat.id
TELEGRAM_CHAT_ID=
